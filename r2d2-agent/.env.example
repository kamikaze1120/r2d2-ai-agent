# ============================================================
# R2D2 — Environment Variables
# Copy this file to .env and fill in the values you need.
# Missing values disable that feature; R2D2 still boots.
# ============================================================

# ---- Server ----------------------------------------------------------------
R2D2_HOST=127.0.0.1          # bind address (use 0.0.0.0 to expose on LAN)
R2D2_PORT=8000
R2D2_ALLOWED_ORIGINS=*       # comma-separated origins, or * for all

# ---- LLM Provider ----------------------------------------------------------
# Pick ONE provider. Set R2D2_LLM_PROVIDER to match.
#
# Options: ollama | anthropic | openai | gemini | custom
#
R2D2_LLM_PROVIDER=ollama

# -- Ollama (local, free) --
OLLAMA_HOST=http://localhost:11434
R2D2_MODEL=llama3.2           # any model you have pulled: llama3.2, mistral, phi3, qwen2.5...

# -- Anthropic Claude (API) --
# ANTHROPIC_API_KEY=sk-ant-...
# R2D2_LLM_PROVIDER=anthropic
# R2D2_MODEL=claude-sonnet-4-6        # or claude-haiku-4-5-20251001, claude-opus-4-8

# -- OpenAI / GPT (API) --
# OPENAI_API_KEY=sk-...
# R2D2_LLM_PROVIDER=openai
# R2D2_MODEL=gpt-4o                  # or gpt-4o-mini, gpt-3.5-turbo

# -- Google Gemini (API) --
# GEMINI_API_KEY=AIza...
# R2D2_LLM_PROVIDER=gemini
# R2D2_MODEL=gemini-1.5-pro          # or gemini-1.5-flash

# -- Custom OpenAI-compatible endpoint (Groq, Together, Mistral, Ollama remote, LM Studio...) --
# CUSTOM_LLM_BASE_URL=https://api.groq.com/openai/v1
# CUSTOM_LLM_API_KEY=gsk_...
# R2D2_LLM_PROVIDER=custom
# R2D2_MODEL=llama-3.1-70b-versatile

# ---- Agent behaviour -------------------------------------------------------
R2D2_MAX_ITERATIONS=12        # max tool-use steps per chat turn
R2D2_GOAL=Generate and scale digital product revenue autonomously.

# ---- Safety ----------------------------------------------------------------
R2D2_SHELL_ALLOWLIST=         # comma-separated allowed shell commands, blank = all
R2D2_APPROVAL_THRESHOLD=0.80  # 0.0–1.0 — listings below this need human approval
R2D2_DRY_RUN=false            # true = no real Etsy/Shopify/Pinterest writes

# ---- Voice (ElevenLabs) ----------------------------------------------------
# Users can also set their own key in the web panel Settings → Voice
ELEVENLABS_API_KEY=sk_...

# ---- Email (SMTP + IMAP) ---------------------------------------------------
EMAIL_ADDRESS=you@example.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_PASSWORD=your-app-password   # use an App Password, not your login password

# ---- Etsy ------------------------------------------------------------------
ETSY_API_KEY=your_etsy_api_key           # from developers.etsy.com
ETSY_OAUTH_TOKEN=your_access_token       # obtained after OAuth flow
ETSY_REFRESH_TOKEN=your_refresh_token
ETSY_SHOP_ID=your_shop_id

# ---- Shopify ---------------------------------------------------------------
SHOPIFY_STORE=mystore.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_...

# ---- Pinterest -------------------------------------------------------------
PINTEREST_ACCESS_TOKEN=your_access_token
PINTEREST_BOARD_ID=your_board_id

# ---- Storage ---------------------------------------------------------------
R2D2_DATA_DIR=~/.r2d2            # where memory, logs, sessions are stored
R2D2_WORKSPACE=~/.r2d2/workspace # sandbox for file ops & generated products
